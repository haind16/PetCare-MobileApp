<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary_blue"
        android:gravity="center_vertical"
        android:paddingTop="14dp"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Thêm thú cưng mới"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginEnd="32dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Tên -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên"
                android:textSize="14sp"
                android:textColor="#333333"/>
            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edit_text_border"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="textPersonName"
                android:textSize="14sp"/>

            <!-- Giới tính -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giới tính"
                android:textSize="14sp"
                android:textColor="#333333"/>
            <EditText
                android:id="@+id/etGender"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edit_text_border"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="text"
                android:textSize="14sp"/>

            <!-- Cân nặng -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cân nặng"
                android:textSize="14sp"
                android:textColor="#333333"/>
            <EditText
                android:id="@+id/etWeight"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edit_text_border"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="numberDecimal"
                android:textSize="14sp"/>

            <!-- Ngày sinh -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ngày sinh"
                android:textSize="14sp"
                android:textColor="#333333"/>
            <EditText
                android:id="@+id/etBirthDate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edit_text_border"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="date"
                android:textSize="14sp"/>

            <!-- Giống -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giống"
                android:textSize="14sp"
                android:textColor="#333333"/>
            <EditText
                android:id="@+id/etBreed"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/edit_text_border"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="text"
                android:textSize="14sp"/>

            <!-- Điều kiện sống -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Điều kiện sống"
                android:textSize="14sp"
                android:textColor="#333333"/>
            <EditText
                android:id="@+id/etLivingCondition"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/edit_text_border"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:inputType="text"
                android:textSize="14sp"/>

            <!-- Nút chọn ảnh -->
            <LinearLayout
                android:id="@+id/btnPickImage"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_icon_blue"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🖼"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Ảnh"
                    android:textSize="14sp"
                    android:textColor="@color/primary_blue"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Nút Xác nhận -->
    <Button
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_purple_btn"
        android:text="Xác nhận thêm thú cưng mới"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textAllCaps="false"
        android:textStyle="bold"/>

</LinearLayout>