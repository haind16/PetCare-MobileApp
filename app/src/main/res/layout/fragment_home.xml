<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header xanh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="@color/primary_blue"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PET CARE"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_bell"
            android:tint="@color/white"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card thú cưng -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/imgPet"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:src="@drawable/pet_welcome"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="12dp">

                        <TextView
                            android:id="@+id/tvPetName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Milo"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvPetAge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tuổi: 3"
                            android:textSize="13sp"
                            android:textColor="#666666"/>

                        <TextView
                            android:id="@+id/tvPetWeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cân nặng: 4.5 kg"
                            android:textSize="13sp"
                            android:textColor="#666666"/>
                    </LinearLayout>

                    <!-- 2 nút dọc -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <Button
                            android:id="@+id/btnInteract"
                            android:layout_width="88dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_interact_btn"
                            android:text="Tương tác"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textAllCaps="false"
                            android:layout_marginBottom="6dp"/>

                        <Button
                            android:id="@+id/btnChangePet"
                            android:layout_width="88dp"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_orange_btn"
                            android:text="Đổi thú cưng"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textAllCaps="false"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Nhắc nhở sắp tới -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhắc nhở sắp tới"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Trạng thái trống -->
            <TextView
                android:id="@+id/tvNoReminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa có nhắc nhở nào"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"/>

            <!-- Danh sách nhắc nhở từ Room -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvReminders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp"/>

            <!-- Nút Thêm lịch mới -->
            <Button
                android:id="@+id/btnAddSchedule"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_purple_btn"
                android:text="Thêm lịch mới"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textAllCaps="false"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>